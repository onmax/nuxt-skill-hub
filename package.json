{
  "name": "nuxt-skill-hub",
  "version": "1.0.0",
  "description": "Experimental Nuxt module that generates a consolidated super-skill with module extensions.",
  "packageManager": "pnpm@10.30.1",
  "repository": "maxi/nuxt-skill-hub",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist",
    "core-content"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "pnpm run dev:prepare && vitest run",
    "test:watch": "vitest watch",
    "test:types": "pnpm run dev:prepare && vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "typecheck": "pnpm run test:types"
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.1",
    "automd": "^0.4.3",
    "consola": "^3.4.0",
    "ofetch": "^1.5.0",
    "pathe": "^2.0.0",
    "pkg-types": "^2.3.0",
    "unagent": "^0.0.8"
  },
  "devDependencies": {
    "@nuxt/devtools": "catalog:nuxt",
    "@nuxt/eslint-config": "catalog:nuxt",
    "@nuxt/module-builder": "catalog:nuxt",
    "@nuxt/schema": "catalog:nuxt",
    "@nuxt/test-utils": "catalog:nuxt",
    "@types/node": "catalog:quality",
    "@vue/test-utils": "catalog:quality",
    "changelogen": "catalog:release",
    "eslint": "catalog:quality",
    "happy-dom": "catalog:quality",
    "nuxt": "catalog:nuxt",
    "typescript": "catalog:quality",
    "vitest": "catalog:quality",
    "vue": "catalog:frontend",
    "vue-tsc": "catalog:quality"
  }
}
